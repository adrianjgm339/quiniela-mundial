generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String              @id @default(uuid())
  email          String              @unique
  passwordHash   String
  displayName    String
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  role           UserRole            @default(USER)
  activeSeasonId String?
  countryCode    String?
  leaguesCreated League[]
  joinRequests   LeagueJoinRequest[]
  memberships    LeagueMember[]
  picks          Pick[]
  notifications  Notification[]
  activeSeason   Season?             @relation(fields: [activeSeasonId], references: [id])
}

model Sport {
  id           String             @id @default(uuid())
  slug         String             @unique
  competitions Competition[]
  translations SportTranslation[]
}

model SportTranslation {
  id      String @id @default(uuid())
  sportId String
  locale  String
  name    String
  sport   Sport  @relation(fields: [sportId], references: [id])

  @@unique([sportId, locale])
}

model Competition {
  id           String                   @id @default(uuid())
  sportId      String
  slug         String                   @unique
  sport        Sport                    @relation(fields: [sportId], references: [id])
  translations CompetitionTranslation[]
  seasons      Season[]
}

model CompetitionTranslation {
  id            String      @id @default(uuid())
  competitionId String
  locale        String
  name          String
  competition   Competition @relation(fields: [competitionId], references: [id])

  @@unique([competitionId, locale])
}

model Season {
  id                   String                 @id @default(uuid())
  competitionId        String
  slug                 String                 @unique
  startDate            DateTime?
  endDate              DateTime?
  defaultScoringRuleId String?
  bracketSlots         BracketSlot[]
  groupStandings       GroupStanding[]
  leagues              League[]
  matches              Match[]
  scoringRules         ScoringRule[]
  competition          Competition            @relation(fields: [competitionId], references: [id])
  defaultScoringRule   ScoringRule?           @relation("SeasonDefaultRule", fields: [defaultScoringRuleId], references: [id])
  scoringConcepts      SeasonScoringConcept[]
  translations         SeasonTranslation[]
  teams                Team[]
  thirdPlaceRankings   ThirdPlaceRanking[]
  activeUsers          User[]
}

model SeasonTranslation {
  id       String @id @default(uuid())
  seasonId String
  locale   String
  name     String
  season   Season @relation(fields: [seasonId], references: [id])

  @@unique([seasonId, locale])
}

model League {
  id            String              @id @default(uuid())
  seasonId      String
  name          String
  joinCode      String              @unique
  createdById   String
  createdAt     DateTime            @default(now())
  scoringRuleId String?
  inviteEnabled Boolean             @default(true)
  joinPolicy    LeagueJoinPolicy    @default(PRIVATE)
  createdBy     User                @relation(fields: [createdById], references: [id])
  scoringRule   ScoringRule?        @relation(fields: [scoringRuleId], references: [id])
  season        Season              @relation(fields: [seasonId], references: [id])
  joinRequests  LeagueJoinRequest[]
  members       LeagueMember[]
  picks         Pick[]
}

model LeagueMember {
  id       String           @id @default(uuid())
  leagueId String
  userId   String
  status   MemberStatus     @default(ACTIVE)
  joinedAt DateTime         @default(now())
  role     LeagueMemberRole @default(MEMBER)
  league   League           @relation(fields: [leagueId], references: [id])
  user     User             @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
}

model LeagueJoinRequest {
  id          String            @id @default(cuid())
  leagueId    String
  userId      String
  status      JoinRequestStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  decidedAt   DateTime?
  decidedById String?
  reason      String?
  league      League            @relation(fields: [leagueId], references: [id])
  user        User              @relation(fields: [userId], references: [id])

  @@unique([leagueId, userId])
  @@index([leagueId, status])
}

model Notification {
  id        String            @id @default(cuid())
  userId    String
  type      NotificationType
  scope     NotificationScope @default(USER)
  title     String
  message   String
  actionUrl String?
  isRead    Boolean           @default(false)
  readAt    DateTime?
  meta      Json?
  createdAt DateTime          @default(now())
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
}

model Team {
  id                 String              @id @default(uuid())
  seasonId           String
  externalId         String
  flagKey            String?
  groupCode          String?
  confed             String?
  isPlaceholder      Boolean             @default(false)
  placeholderRule    String?
  createdAt          DateTime            @default(now())
  bracketSlots       BracketSlot[]
  groupStandings     GroupStanding[]
  awayMatches        Match[]             @relation("AwayTeam")
  homeMatches        Match[]             @relation("HomeTeam")
  season             Season              @relation(fields: [seasonId], references: [id])
  translations       TeamTranslation[]
  thirdPlaceRankings ThirdPlaceRanking[]

  @@unique([seasonId, externalId])
}

model TeamTranslation {
  id     String @id @default(uuid())
  teamId String
  locale String
  name   String
  team   Team   @relation(fields: [teamId], references: [id])

  @@unique([teamId, locale])
}

model Match {
  id                String              @id @default(uuid())
  seasonId          String
  externalId        String
  phaseCode         String
  groupCode         String?
  matchNumber       Int?
  venue             String?
  utcDateTime       DateTime
  closeUtc          DateTime?
  closeMinutes      Int?
  status            MatchStatus         @default(SCHEDULED)
  statusRaw         String?
  resultConfirmed   Boolean             @default(false)
  resultConfirmedAt DateTime?
  pointsNotifiedAt  DateTime?
  homeTeamId        String
  awayTeamId        String
  homeScore         Int?
  awayScore         Int?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  advanceMethod     MatchAdvanceMethod?
  advanceTeamId     String?
  awayErrors        Int?
  awayHits          Int?
  homeErrors        Int?
  homeHits          Int?
  awayTeam          Team                @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam          Team                @relation("HomeTeam", fields: [homeTeamId], references: [id])
  season            Season              @relation(fields: [seasonId], references: [id])
  picks             Pick[]

  @@unique([seasonId, externalId])
  @@index([seasonId, utcDateTime])
  @@index([seasonId, resultConfirmed, resultConfirmedAt])
}

model Pick {
  id              String      @id @default(uuid())
  leagueId        String
  matchId         String
  userId          String
  homePred        Int
  awayPred        Int
  status          PickStatus  @default(VALID)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  koWinnerTeamId  String?
  predTotalErrors Int?
  predTotalHits   Int?
  league          League      @relation(fields: [leagueId], references: [id])
  match           Match       @relation(fields: [matchId], references: [id])
  user            User        @relation(fields: [userId], references: [id])
  scores          PickScore[]

  @@unique([leagueId, matchId, userId])
  @@index([leagueId])
  @@index([matchId])
}

model ScoringRule {
  id               String              @id
  name             String
  description      String?
  isGlobal         Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  seasonId         String?
  leagues          League[]
  pickScores       PickScore[]
  season           Season?             @relation(fields: [seasonId], references: [id])
  details          ScoringRuleDetail[]
  seasonsAsDefault Season[]            @relation("SeasonDefaultRule")
}

model ScoringRuleDetail {
  id     String      @id @default(cuid())
  ruleId String
  code   String
  points Int
  rule   ScoringRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, code])
}

model PickScore {
  id      String            @id @default(cuid())
  pickId  String
  ruleId  String
  points  Int
  pick    Pick              @relation(fields: [pickId], references: [id], onDelete: Cascade)
  rule    ScoringRule       @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  details PickScoreDetail[]

  @@unique([pickId, ruleId])
}

model PickScoreDetail {
  id          String    @id @default(cuid())
  pickScoreId String
  code        String
  points      Int
  pickScore   PickScore @relation(fields: [pickScoreId], references: [id], onDelete: Cascade)

  @@unique([pickScoreId, code])
  @@index([pickScoreId])
  @@index([code])
}

model GroupStanding {
  id             String   @id @default(cuid())
  seasonId       String
  groupCode      String
  teamId         String
  played         Int      @default(0)
  won            Int      @default(0)
  drawn          Int      @default(0)
  lost           Int      @default(0)
  gf             Int      @default(0)
  ga             Int      @default(0)
  gd             Int      @default(0)
  points         Int      @default(0)
  posGroup       Int?
  needsManual    Boolean  @default(false)
  manualOverride Boolean  @default(false)
  manualReason   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  season         Season   @relation(fields: [seasonId], references: [id])
  team           Team     @relation(fields: [teamId], references: [id])

  @@unique([seasonId, groupCode, teamId])
  @@index([seasonId, groupCode])
}

model ThirdPlaceRanking {
  id             String   @id @default(cuid())
  seasonId       String
  teamId         String
  groupCode      String
  points         Int
  gd             Int
  gf             Int
  ga             Int
  rankGlobal     Int?
  isQualified    Boolean  @default(false)
  needsManual    Boolean  @default(false)
  manualOverride Boolean  @default(false)
  manualReason   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  season         Season   @relation(fields: [seasonId], references: [id])
  team           Team     @relation(fields: [teamId], references: [id])

  @@unique([seasonId, teamId])
  @@index([seasonId])
}

model BracketSlot {
  id              String          @id @default(cuid())
  seasonId        String
  round           BracketRound    @default(R32)
  matchNo         Int
  slot            BracketSlotType
  placeholderText String?
  teamId          String?
  needsManual     Boolean         @default(false)
  manualOverride  Boolean         @default(false)
  manualReason    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  season          Season          @relation(fields: [seasonId], references: [id])
  team            Team?           @relation(fields: [teamId], references: [id])

  @@unique([seasonId, round, matchNo, slot])
  @@index([seasonId, round])
}

model SeasonScoringConcept {
  id       String  @id @default(cuid())
  seasonId String
  code     String
  label    String?
  season   Season  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([seasonId, code])
  @@index([seasonId])
}

model Waitlist {
  id          String           @id @default(cuid())
  email       String           @unique
  phone       String?
  name        String?
  interest    WaitlistInterest @default(BOTH)
  locale      String?
  source      String?
  referrer    String?
  path        String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

enum UserRole {
  USER
  ADMIN
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum LeagueMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum LeagueJoinPolicy {
  PUBLIC
  PRIVATE
  APPROVAL
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  SUSPENDED
}

enum PickStatus {
  VALID
  LATE
  VOID
}

enum MatchAdvanceMethod {
  ET
  PEN
}

enum BracketRound {
  R32
}

enum BracketSlotType {
  HOME
  AWAY
}

enum WaitlistInterest {
  SOCCER
  BASEBALL
  BOTH
}

enum NotificationType {
  LEAGUE_JOIN_REQUEST_PENDING
  LEAGUE_JOIN_APPROVED
  LEAGUE_JOIN_REJECTED
  APP_ANNOUNCEMENT
}

enum NotificationScope {
  USER
  SYSTEM
}
